# ====== Google Sheet backend (reviews) ======
# The Vercel app calls a Google Apps Script Web App (google-apps-script/Code.gs)
# bound to your reviews Google Sheet. No Google API keys are required.
# Web App URL printed when you Deploy the Apps Script (ends with /exec).
SHEET_WEBAPP_URL=https://script.google.com/macros/s/XXXXXXXX/exec
# Shared token shared between Vercel and the Apps Script (the TOKEN constant).
# Generate a strong value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SHEET_WEBAPP_TOKEN=your_long_random_shared_token

# ====== Admin panel ======
# Checked by /api/admin/reviews against the `password` request header
# (the /reviewmanagement admin page sends it).
ADMIN_PASSWORD=change_me
